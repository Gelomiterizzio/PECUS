{
  "name": "pecus",
  "version": "1.0.0",
  "private": true,
  "description": "PECUS — Plataforma inteligente de monitoreo y gestión ganadera",
  "author": "PECUS Team",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @pecus/api prisma:generate",
    "db:migrate": "pnpm --filter @pecus/api prisma:migrate",
    "db:seed": "pnpm --filter @pecus/api prisma:seed",
    "db:studio": "pnpm --filter @pecus/api prisma:studio",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
