# ─────────────────────────────────────────────
# PECUS — Variables de entorno
# ─────────────────────────────────────────────

# ── Base de datos (PostgreSQL) ──
POSTGRES_USER=pecus
POSTGRES_PASSWORD=pecus_secret
POSTGRES_DB=pecus
DATABASE_URL="postgresql://pecus:pecus_secret@localhost:5432/pecus?schema=public"

# ── API (NestJS) ──
API_PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── Telemetría IoT simulada ──
IOT_SIMULATION_ENABLED=true
IOT_SIMULATION_INTERVAL_MS=8000

# ── Frontend (Next.js) ──
NEXT_PUBLIC_API_URL=http://localhost:4000
